# Credenciales de Supabase para el ranking global de los juegos.
# Sin estas variables el juego funciona igual, pero el ranking global
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Game server autoritativo de tiempo real (server/, socket.io en Railway).
# Lo usan Bomba Palabra (word-bomb): valida palabras contra el diccionario
# server-side y arbitra la mecha; y PONG en sala: fisica 1v1 arbitrada por el
# server. Bomba Palabra NO degrada sin esta URL (muestra "no disponible"); PONG
# si degrada (la sala cae a un partido local vs IA). Los demas juegos no la usan.
# Ejemplo: https://minigames-server.up.railway.app
VITE_GAME_SERVER_URL=
