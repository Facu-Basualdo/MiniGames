# Credenciales de Supabase para el ranking global de los juegos.
# Sin estas variables el juego funciona igual, pero el ranking global
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Game server autoritativo de tiempo real (server/, socket.io en Railway).
# Lo usan Bomba Palabra (word-bomb): valida palabras contra el diccionario
# server-side y arbitra la mecha; y PONG en sala: fisica 1v1 arbitrada por el
# server. Bomba Palabra NO degrada sin esta URL (muestra "no disponible"); PONG
# si degrada (la sala cae a un partido local vs IA). Los demas juegos no la usan.
# Seteada, la landing muestra en la barra si el server esta vivo y su ping (pega
# al /health).
# Ejemplo: https://minigames-server.up.railway.app
VITE_GAME_SERVER_URL=

# Game server de respaldo (opcional). Si la URL de arriba no responde al /health,
# el front usa esta: la landing lo avisa ("Servidor de respaldo", en ambar) y los
# juegos conectan ahi. Vacia = sin respaldo, y entonces no se paga ningun health
# check extra al conectar. Tiene que ser OTRO deploy del mismo server/ (mismos
# namespaces), con el origin de Vercel en su ALLOWED_ORIGINS.
# OJO: la sala entera tiene que terminar en el MISMO server o los jugadores quedan
# en partidas separadas sin verse.
VITE_GAME_SERVER_FALLBACK_URL=
